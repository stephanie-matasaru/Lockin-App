<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>  <?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lockin.client.controllers.LoginController"
      stylesheets="@/styles.css"
      styleClass="root">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox spacing="15" maxWidth="300" styleClass="login-container">

        <Label text="LOCK-IN SYSTEM" styleClass="header-title" style="-fx-font-size: 22px; -fx-alignment: center;"/>

        <Label text="Username" style="-fx-text-fill: white;"/>
        <TextField fx:id="usernameField" promptText="Enter username" styleClass="login-field"/>

        <Label text="Password" style="-fx-text-fill: white;"/>
        <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="login-field"/>

        <CheckBox fx:id="chkOperator" text="Login as Operator" textFill="#00e5ff"/>

        <Button fx:id="loginButton" text="LOGIN" onAction="#onLoginButtonClick" maxWidth="Infinity" styleClass="login-btn"/>
        <Label fx:id="messageLabel" text="" style="-fx-text-fill: #ff4444;"/>

        <Button text="Register new account" onAction="#onRegisterLinkClick"
                style="-fx-background-color: transparent; -fx-text-fill: #00e5ff; -fx-underline: true; -fx-cursor: hand;"/>

    </VBox>
</VBox>