<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.myname.controllers.LoginController">

    <Label text="Please Login" />

    <TextField fx:id="usernameField" promptText="Username" maxWidth="200" />

    <Button text="Login" onAction="#handleLoginButton"/>

    <Label fx:id="statusLabel" text="" />
</VBox>